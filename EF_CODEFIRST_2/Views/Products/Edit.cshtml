@model EF_CODEFIRST_2.Models.Product

@{
    ViewBag.Title = "Edit";
    Layout = "~/Views/Shared/_LayoutPage1.cshtml";
}

<h2>Edit</h2>

<form action="/Products/edit/@Model.ProductID" method="post">
    <input type="hidden" name="ProductID" value="@Model.ProductID" />
    <div class="row">
        <div class="col-md-6">
            <label for="ProductName">Product Name</label>
            <input type="text" class="form-control" id="ProductName" name="ProductName" placeholder="Product Name  " value="@Model.ProductName" />

        </div>

        <div class="col-md-6">
            <label for="Price">Price</label>
            <input type="number" class="form-control" id="Price" name="Price" placeholder="Price "
                   value="@Model.Price" />

        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <label for="DateOfPurchase">DateOfPurchase</label>
            <input type="date" class="form-control" id="DateOfPurchase" name="DateOfPurchase" placeholder="DateOfPurchase"
                   value="@Model.DateOfPurchase.Value.ToString("yyyy-MM-dd")" />

        </div>

        <div class="col-md-6">
            <label for="AvailabilityStatus">AvailabilityStatus</label>
            <select class="form-control" id="AvailabilityStatus" name="AvailabilityStatus" placeholder="AvailabilityStatus ">
                @if (Model.AvailabilityStatus == "InStock")
                {
                    <option value="Instock" selected>
                        In Stock
                    </option>
                    <option value="OutOfStock">
                        Out Of Stock
                    </option>
                }

                else
                {
                    <option value="Instock" >
                        In Stock
                    </option>
                    <option value="OutOfStock"selected>
                        Out Of Stock
                    </option>
                }
            </select>

        </div>
    </div>


    <div class="row">
        <div class="col-md-6">
            <label for="BrandID">BrandID</label>
            <input type="number" class="form-control" id="BrandID" name="BrandID" placeholder="BrandID  "
                   value="@Model.BrandID" />

        </div>

        <div class="col-md-6">
            <label for="CategoryID">CategoryID</label>
            <input type="text" class="form-control" id="CategoryID" name="CategoryID" placeholder="CategoryID "
                   value="@Model.CategoryID" />

        </div>
    </div>

    <div class="row">
        <div class="mx-3 form-check">
            <label for="Active">Active</label>
            <input type="checkbox" class="form-check-input" id="Active" name="Active" value="true"
                   checked="@Model.Active  " />
            <label class=" form-check-label" for="Active">Active</label>

        </div>


    </div>
    <button type="submit" class="btn btn-success">Save</button>
    <a href="/Products" class="btn btn-danger">Cancel</a>
</form>

